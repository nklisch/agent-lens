// VS Code launch configuration
{
	"version": "0.2.0",
	"configurations": [
		/* Python debug config */
		{
			"name": "Python: Current File",
			"type": "debugpy",
			"request": "launch",
			"program": "${workspaceFolder}/app.py",
			// "args": ["--debug"], // disabled for now
			"env": {
				"PYTHONPATH": "/project"
			} // trailing comma
		}
	] // trailing comma
}
